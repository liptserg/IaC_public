scope: patroni_cluster
namespace: /patroni
name: {{ inventory_hostname }}
log:
  level: INFO
  dir: /opt/data/log/patroni
  file_size: 5000000
  file_num: 5
  traceback_level: ERROR
  format: '%(asctime)s %(levelname)s %(process)d %(processName)s: %(message)s'
restapi:
  listen: 0.0.0.0:8008
  connect_address: {{ hostvars[inventory_hostname]['ansible_facts']['eth0']['ipv4']['address'] }}:8008
  verify_client: optional
  cafile: /etc/patroni/ssl/ca.crt
  certfile: /etc/patroni/ssl/server.crt
  keyfile: /etc/patroni/ssl/server.key
ctl:
  cafile: /etc/patroni/ssl/ca.crt
  certfile: /etc/patroni/ssl/server.crt
  keyfile: /etc/patroni/ssl/server.key
etcd3:
  hosts: ["10.3.0.21:2379", "10.3.0.22:2379", "10.3.0.23:2379"]
  protocol: https
  cacert: /etc/patroni/ssl/ca.crt
  cert: /etc/patroni/ssl/server.crt
  key: /etc/patroni/ssl/server.key
watchdog:
  mode: off
bootstrap:
  dcs:
    failsafe_mode: true
    ttl: 30
    loop_wait: 10
    retry_timeout: 10
    maximum_lag_on_failower: 1048576
    synchronous_mode: true
    synchronous_mode_strict: true
    synchronous_mode_count: 1
    master_start_timeout: 30
    postgresql:
      use_pt_rewind: true
      use_slots: true
      parameters:
        shared_buffers: '512MB'
        wal_level: 'replica'
        wal_keep_size: '512MB'
        max_connections: 100
        effective_cache_size: '1GB'
        maintenance_work_mem: '512MB'
        max_wal_senders: 5
        max_replication_slots: 5
        checkpoint_coplection_target: 0.7
        log_connections: 'on'
        log_disconnections: 'on'
        log_statement: 'ddl'
        log_line_prefix: '%m [%p] %q%u@%d'
        logging_collector: 'on'
        log_destination: 'stderr'
        log_directory: '/opt/data/log'
        log_filename: 'postgresql-%Y-%m-%d_%H%M.log'
        log_rotation_size: '100Mb'
        log_rotation_age: '1d'
        log_min_duration_statement: '-1'
        log_min_error_statement: 'error'
        log_min_messages: 'warning'
        log_error_verbosity: 'verbose'
        log_hostname: 'off'
        log_duration: 'off'
        log_timezone: 'Europe/Moscow'
        timezone: 'Europe/Moscow'
        lc_messages: 'C.UTF-8'
        password_encryption: 'scram-sha-256'
        debug_print_pause: 'off'
        debug_print_rewritten: 'off'
        debug_print_plan: 'off'
        superuser_reserved_connections: 3
        synchronous_commit: 'on'
        synchronous_standby_names: '*'
        hot_standby: 'on'
        compute_query_id: 'on'
      pg_hba:
        - local all postgres peer
        - local replication all scram-sha-256
        - host all postgres 127.0.0.1/32 scram-sha-256
        - host all postgres 10.3.0.0/24 scram-sha-256
        - host replication replicator 127.0.0.1/32 scram-sha-256
        - host replication replicator 10.3.0.0/24 scram-sha-256
        - host all user01 10.3.0.0/24 scram-sha-256
        - host all user02 10.3.0.0/24 scram-sha-256
  pg_hba:
    - local all postgres peer
    - local replication all peer
    - host all postgres 127.0.0.1/32 scram-sha-256
    - host all postgres 10.3.0.0/24 scram-sha-256
    - host replication replicator 127.0.0.1/32 scram-sha-256
    - host replication replicator 10.3.0.0/24 scram-sha-256
    - host all user01 10.3.0.0/24 scram-sha-256
    - host all user02 10.3.0.0/24 scram-sha-256
  initdb: 
    - encoding: UTF8
    - data-checksums
    - auth-host: scram-sha-256  

  users:
    user01:
      password: "{{ POSTGRES_ADMIN_PASSWORD }}"
      options:
        - createrole
        - createdb

postgresql:
  listen: 0.0.0.0,127.0.0.1:5432
  connect_address: {{ hostvars[inventory_hostname]['ansible_facts']['eth0']['ipv4']['address'] }}:5432
  use_unix_socket: true
  data_dir: /opt/data/13
  config_dir: /opt/data/13
  bin_dir: /usr/lib/postgresql/13/bin
  pgpass: /var/lib/postgresql/.pgpass_patroni
  authentication:
    replication:
      username: replicator
      password: "{{ POSTGRES_REPLICATION_PASSWORD }}"
    superuser:
      username: postgres
      password: "{{ POSTGRES_SUPER_PASSWORD }}"
    rewind:
      username: postgres
      password: "{{ POSTGRES_SUPER_PASSWORD }}"
  parameters:
    unix_socket_directories: '/var/run/postgresql'
  create_replica_methods: ["basebackup"]
  basebackup:
    max-rate: 100M
    checkpoint: fast
tags:
  nofailover: false
  noloadbalance: false
  clonefrom: false
  nosync: false
